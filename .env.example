# =============================================================================
# Environment variables for the Amriky LLC site
#
# For a Vercel deployment, add the VITE_* variables below in:
#   Vercel Project → Settings → Environment Variables
# Only the VITE_* variables are needed for the public (static) site.
# =============================================================================

# --- Google Maps (via Manus forge proxy) ---------------------------------
# Powers the map on the Contact page. Without these the site still works,
# but the map area stays blank.
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# --- Optional: Umami analytics -------------------------------------------
# Uncomment the analytics <script> in client/index.html to use these.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# =============================================================================
# The variables below are only needed if you also run the full Express
# server (auth / database). They are NOT required for the static Vercel
# deployment configured in vercel.json.
# =============================================================================
# DATABASE_URL=
# JWT_SECRET=
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
# VITE_APP_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
